# load common envs across all projects (local)
dotenv_if_exists "${PWD}/.env.dev"

dotenv_if_exists "${PWD}/dagster-workspace/projects/data_platform/.env.dev"
dotenv_if_exists "${PWD}/dagster-workspace/projects/team_ops/.env.dev"
dotenv_if_exists "${PWD}/dagster-workspace/projects/team_ops/.env.polaris"

# Manual envs for prod and infra
# dotenv_if_exists "${PWD}/.env.prod"
# dotenv_if_exists "${PWD}/infrastructure/.env"

if [[ "${ENVIRONMENT}" == "prod" ]]; then
  export DAGSTER_HOME="${PWD}/data/dagster_home_prod"
else
  # Local folder for saving Dagster runs and assets so they persist between sessions
  export DAGSTER_HOME="${PWD}/data/dagster_home"
fi

use flake ~/Developer/nix-project-flakes/datastack

# source dagster-workspace/deployments/local/.venv/bin/activate
# source "${PWD}/dagster-workspace/projects/team_ops/.venv/bin/activate"

# Overwrite or append PYTHONPATH from nix environment
export PYTHONPATH="${PYTHONPATH}:${PWD}/dagster-workspace/projects/data_platform/src"
export PYTHONPATH="${PYTHONPATH}:${PWD}/dagster-workspace/projects/physical_risk_impact/src"
export PYTHONPATH="${PYTHONPATH}:${PWD}/dagster-workspace/projects/team_ops/src"
export PATH="/Users/melchior/Developer/polaris:$PATH"
